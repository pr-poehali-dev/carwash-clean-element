{
  "tests": [
    {
      "name": "Register new client",
      "method": "POST",
      "path": "/register",
      "body": {"name": "Тест Тестов", "phone": "+79991234599", "password": "test123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login admin",
      "method": "POST",
      "path": "/login",
      "body": {"phone": "+70000000000", "password": "admin123"},
      "expectedStatus": 200,
      "expectedBody": {"is_admin": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/login",
      "body": {"phone": "+70000000000", "password": "wrong"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
